<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.1.xsd">

  <changeSet id="changelog-001-create-hotel-schema" author="p.mironenko">

    <createTable schemaName="PUBLIC" tableName="hotel">
      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="name" type="varchar(255)">
        <constraints nullable="false"/>
      </column>
      <column name="description" type="varchar(2000)"/>
      <column name="brand" type="varchar(255)">
        <constraints nullable="false"/>
      </column>
      <column name="house_number" type="int">
        <constraints nullable="false"/>
      </column>
      <column name="street" type="varchar(255)">
        <constraints nullable="false"/>
      </column>
      <column name="city" type="varchar(255)">
        <constraints nullable="false"/>
      </column>
      <column name="country" type="varchar(255)">
        <constraints nullable="false"/>
      </column>
      <column name="post_code" type="varchar(20)">
        <constraints nullable="false"/>
      </column>
      <column name="phone" type="varchar(20)">
        <constraints nullable="false"/>
      </column>
      <column name="email" type="varchar(255)">
        <constraints nullable="false"/>
      </column>
      <column name="check_in" type="varchar(20)"/>
      <column name="check_out" type="varchar(20)"/>
    </createTable>

    <createTable schemaName="PUBLIC" tableName="amenity">
      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true"/>
      </column>
      <column name="name" type="varchar(255)">
        <constraints nullable="false" unique="true"/>
      </column>
    </createTable>

    <createTable schemaName="PUBLIC" tableName="hotel_amenity">
      <column name="hotel_id" type="bigint">
        <constraints nullable="false"
          foreignKeyName="fk_hotel_amenity_hotel"
          references="hotel(id)"/>
      </column>
      <column name="amenity_id" type="bigint">
        <constraints nullable="false"
          foreignKeyName="fk_hotel_amenity_amenity"
          references="amenity(id)"/>
      </column>
    </createTable>

    <addPrimaryKey tableName="hotel_amenity"
      columnNames="hotel_id, amenity_id"
      constraintName="pk_hotel_amenity"/>

    <createIndex tableName="hotel" indexName="index_hotel_brand">
      <column name="brand"/>
    </createIndex>

    <createIndex tableName="hotel" indexName="index_hotel_city">
      <column name="city"/>
    </createIndex>

    <createIndex tableName="hotel" indexName="index_hotel_country">
      <column name="country"/>
    </createIndex>
  </changeSet>

</databaseChangeLog>
